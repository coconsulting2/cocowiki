# .env.example — variables del stack de producción coco
#
# Copia este archivo a `.env` (lo hace install.sh automáticamente) y rellena
# los valores. install.sh puede generar varios de estos por ti de forma
# interactiva (host público auto-detectado, secretos, DATABASE_URL ensamblada).
#
# NUNCA commitees el `.env` real con secretos.

# ──────────────────────────────────────────────────────────────────────────
# Host público / TLS
# ──────────────────────────────────────────────────────────────────────────
# DNS público de EC2 o tu dominio. Lo auto-detecta install.sh vía IMDSv2.
PUBLIC_HOST=ec2-XX-XX-XX-XX.compute-1.amazonaws.com

# Dominio real para Let's Encrypt (TLS válido). Déjalo VACÍO para usar el
# certificado interno auto-firmado de Caddy (sirve con solo IP/DNS de EC2).
# Ej.: SITE_ADDRESS=tudominio.com
SITE_ADDRESS=

# Email opcional para avisos de ACME / Let's Encrypt (solo si usas dominio).
ACME_EMAIL=

# URL pública del API que se inyecta en el BUNDLE DEL NAVEGADOR (build-time).
# Debe terminar en /api porque el backend monta todo bajo /api y Caddy
# enruta /api/* al backend sin quitar el prefijo.
PUBLIC_API_BASE_URL=https://ec2-XX-XX-XX-XX.compute-1.amazonaws.com/api

# Modo dev del frontend (build-time). En producción: false.
PUBLIC_IS_DEV=false

# Origen permitido por CORS en el backend. = el origen público https.
CORS_ORIGIN=https://ec2-XX-XX-XX-XX.compute-1.amazonaws.com

# ──────────────────────────────────────────────────────────────────────────
# Base de datos (PostgreSQL)
# ──────────────────────────────────────────────────────────────────────────
# DATABASE_URL la ENSAMBLA install.sh a partir de las partes de abajo
# (URL-encode del password incluido). Si usas una BD externa (RDS), puedes
# poner aquí la cadena completa directamente.
DATABASE_URL=postgresql://coco:changeme@postgres:5432/coco?schema=public

# Partes usadas cuando el perfil "localdb" está activo (Postgres co-locado).
# POSTGRES_HOST=postgres  => usa el contenedor local (perfil localdb).
# Cualquier otro host => BD externa, sin perfil localdb.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=coco
POSTGRES_USER=coco
POSTGRES_PASSWORD=changeme

# ──────────────────────────────────────────────────────────────────────────
# Almacenamiento (S3)
# ──────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_S3_BUCKET=coco-consulting-prod-XXXXXXXXXXXX

# En EC2 el IAM instance role provee las credenciales AUTOMÁTICAMENTE: deja
# estas dos en blanco/comentadas. Solo descoméntalas para uso fuera de EC2.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Secretos
# ──────────────────────────────────────────────────────────────────────────
# AES_SECRET_KEY debe tener EXACTAMENTE 32 caracteres. install.sh lo genera
# si lo dejas vacío.
AES_SECRET_KEY=

# JWT_SECRET: install.sh lo auto-genera si lo dejas vacío.
JWT_SECRET=

# Cifrado de comentarios/chat (REQUERIDO en producción): 64 caracteres hex c/u
# (32 bytes). install.sh los auto-genera si los dejas vacíos.
CHAT_CURSOR_SECRET=
CHAT_MESSAGE_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# Seeding
# ──────────────────────────────────────────────────────────────────────────
# Si es true, el entrypoint del backend siembra datos demo en el primer arranque.
SEED_DUMMY_DATA=false

# ──────────────────────────────────────────────────────────────────────────
# Integraciones opcionales (descomenta solo las que uses)
# ──────────────────────────────────────────────────────────────────────────
# MAIL_USER=                 # Usuario SMTP para notificaciones por correo
# MAIL_PASSWORD=             # Password/app-password SMTP
# MAIL_SMTP_HOST=            # Host SMTP (ej. smtp.gmail.com)
# MAIL_SMTP_PORT=            # Puerto SMTP (ej. 587)
# DUFFEL_ACCESS_TOKEN=       # Token API de Duffel (búsqueda/reserva de vuelos)
# FLIGHT_PROVIDER=           # Proveedor de vuelos activo (ej. duffel)
# BANXICO_API_KEY=           # API key de Banxico (tipo de cambio MXN)
# WISE_CLIENT_ID=            # Client ID de Wise (pagos/transferencias)
# WISE_CLIENT_SECRET=        # Client secret de Wise
# VAPID_PUBLIC_KEY=          # Clave pública VAPID (web push notifications)
# VAPID_PRIVATE_KEY=         # Clave privada VAPID
# VAPID_MAILTO=              # mailto: de contacto para web push (VAPID)
# SCHEDULER_ENABLED=         # true para habilitar tareas programadas/cron
