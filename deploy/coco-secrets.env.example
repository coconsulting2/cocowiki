# coco-secrets.env.example — integraciones LOCALES para deploy-all.sh
#
# Copia este archivo a `coco-secrets.env` (mismo directorio) y rellena solo lo
# que uses. `deploy-all.sh` lo carga AUTOMÁTICAMENTE y reenvía estas claves a la
# instancia, donde `install.sh` las escribe en el `.env` del servidor.
#
#   cp coco-secrets.env.example coco-secrets.env
#   # edita coco-secrets.env y luego:
#   ./deploy-all.sh
#
# Override del nombre/ruta:  SECRETS_FILE=/ruta/a/archivo ./deploy-all.sh
#
# IMPORTANTE: `coco-secrets.env` lleva secretos y está GITIGNORED — NUNCA lo
# commitees. Deja en blanco lo que no uses (vacío = feature deshabilitado).

# ── Correo (SMTP) ──────────────────────────────────────────────────────────
MAIL_USER=
MAIL_PASSWORD=
MAIL_SMTP_HOST=          # ej. smtp.office365.com
MAIL_SMTP_PORT=          # ej. 587

# ── Vuelos / hospedaje (Duffel) ────────────────────────────────────────────
DUFFEL_ACCESS_TOKEN=
FLIGHT_PROVIDER=         # ej. duffel

# ── Tipo de cambio (Banxico) ───────────────────────────────────────────────
BANXICO_API_KEY=

# ── Pagos / transferencias (Wise) ──────────────────────────────────────────
WISE_CLIENT_ID=
WISE_CLIENT_SECRET=

# ── Web push (VAPID) ───────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=            # ej. mailto:tu@correo.com

# ── Tareas programadas / cron ──────────────────────────────────────────────
SCHEDULER_ENABLED=       # true para habilitar el scheduler

# ── Admin inicial (opcional) ───────────────────────────────────────────────
DITTA_ADMIN_INITIAL_PASSWORD=

# ── Avanzado (normalmente vacío) ───────────────────────────────────────────
# Rama/PR a desplegar en lugar de main:
# BRANCH_BACKEND=
# BRANCH_FRONTEND=
# BRANCH_COCOWIKI=
# Secretos fijos (si los dejas vacíos, install.sh los autogenera en el server):
# AES_SECRET_KEY=
# JWT_SECRET=
